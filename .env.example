# -----------------------------------------------------------------------
# Required
# -----------------------------------------------------------------------

# Shared API key — validated on inbound requests (X-API-Key header) and
# sent on outbound callbacks to Lychee.
# Must match AI_VISION_NSFW_API_KEY in your Lychee .env.
VISION_NSFW_API_KEY=change-me

# Lychee base URL for callbacks. No trailing slash.
VISION_NSFW_LYCHEE_API_URL=https://lychee.example.com

# -----------------------------------------------------------------------
# Classification — quick start with a preset
# -----------------------------------------------------------------------

# Load a named preset as the baseline for block / review / sensitive.
# Valid values: strict | moderation | nude_female | permissive | social_media
# Individual BLOCK / REVIEW / SENSITIVE settings below override the preset.
#
# VISION_NSFW_PRESET=strict

# -----------------------------------------------------------------------
# Classification — global thresholds (fallbacks for all tiers)
# -----------------------------------------------------------------------

# Minimum NudeNet confidence (0.0–1.0) for a detection to trigger any tier.
# VISION_NSFW_CONFIDENCE_THRESHOLD=0.1

# Minimum fraction of the image area (0.0–1.0) a detection must cover.
# 0.0 = no area filter (default). Raise to ignore detections on tiny regions.
# VISION_NSFW_AREA_RATIO_THRESHOLD=0.0

# Absolute confidence floor applied before any tier evaluation.
# Detections below this value are discarded entirely (not included in all_detected
# or any tier list). 0.0 = keep all NudeNet output (default).
# Raise to suppress near-zero-confidence noise, e.g.:
# VISION_NSFW_DEBUG_DETECT_THRESHOLD=0.01

# -----------------------------------------------------------------------
# Classification — tier configuration
#
# Each tier accepts a JSON object with:
#   labels            list of NudeNet label strings
#   confidence        float | null  (overrides global threshold for this tier)
#   area_ratio        float | null  (overrides global area threshold)
#   label_thresholds  object mapping label → {confidence?, area_ratio?}
#
# Alternatively, set sub-keys with the __ delimiter:
#   VISION_NSFW_BLOCK__CONFIDENCE=0.8
#   VISION_NSFW_BLOCK__LABELS='["FEMALE_GENITALIA_EXPOSED","ANUS_EXPOSED"]'
# -----------------------------------------------------------------------

# Block tier — sets should_block = true in the callback.
# Default: FEMALE_GENITALIA_EXPOSED, MALE_GENITALIA_EXPOSED, ANUS_EXPOSED
# VISION_NSFW_BLOCK='{"labels": ["FEMALE_GENITALIA_EXPOSED", "MALE_GENITALIA_EXPOSED", "ANUS_EXPOSED"]}'

# Review tier — sets should_review = true in the callback.
# Default: BUTTOCKS_EXPOSED, FEMALE_BREAST_EXPOSED
# VISION_NSFW_REVIEW='{"labels": ["BUTTOCKS_EXPOSED", "FEMALE_BREAST_EXPOSED"]}'

# Sensitive tier — sets is_sensitive = true in the callback.
# Default: FEMALE_BREAST_COVERED, FEMALE_GENITALIA_COVERED, ANUS_COVERED, BUTTOCKS_COVERED, BELLY_EXPOSED
# VISION_NSFW_SENSITIVE='{"labels": ["FEMALE_BREAST_COVERED", "FEMALE_GENITALIA_COVERED", "ANUS_COVERED", "BUTTOCKS_COVERED", "BELLY_EXPOSED"]}'

# -----------------------------------------------------------------------
# Connectivity
# -----------------------------------------------------------------------

# Set to false in development with self-signed certificates.
# VISION_NSFW_VERIFY_SSL=true

# Skip the Lychee connectivity check at startup (useful in dev).
# VISION_NSFW_SKIP_LYCHEE_CHECK=false

# -----------------------------------------------------------------------
# Storage and queue
# -----------------------------------------------------------------------

# Shared volume mount point for Lychee photo files.
# VISION_NSFW_PHOTOS_PATH=/data/photos

# Queue backend: database (SQLite, default) or redis
# VISION_NSFW_QUEUE_BACKEND=database

# SQLite queue storage directory (used when queue_backend=database).
# VISION_NSFW_STORAGE_PATH=/data/queue

# Maximum number of pending jobs (0 = unlimited).
# VISION_NSFW_QUEUE_MAX_SIZE=0

# -----------------------------------------------------------------------
# Performance
# -----------------------------------------------------------------------

# Number of threads for CPU-bound inference.
# VISION_NSFW_THREAD_POOL_SIZE=1

# Number of Uvicorn worker processes.
# VISION_NSFW_WORKERS=1

# -----------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------

# VISION_NSFW_LOG_LEVEL=info
